{
  "name": "ai-tools-catalogue-govuk-11ty",
  "version": "0.1.0",
  "private": true,
  "description": "Static catalogue of AI tools in use within the public sector, built with Eleventy and the GOV.UK Design System.",
  "license": "Crown Copyright",
  "scripts": {
    "clean": "rm -rf _site dist .cache",
    "serve": "eleventy --serve --incremental",
    "watch:css": "sass --quiet-deps --load-path=. --load-path=node_modules --watch src/assets/scss:_site/assets/css",
    "build:css": "sass --quiet-deps --load-path=. --load-path=node_modules --no-source-map src/assets/scss:dist/assets/css",
    "build": "npm run clean && npm run build:css && npm run build:11ty",
    "dev": "npm-run-all -p watch:css serve"
  },
  "oldscripts": {
    "clean": "rm -rf _site dist .cache",
    "build:css": "sass --quiet-deps --load-path=. --load-path=node_modules --no-source-map src/assets/scss:dist/assets/css",
    "build:11ty": "eleventy",
    "build": "npm run clean && npm run build:css && npm run build:11ty",
    "serve": "npm run build:css && eleventy --serve --incremental",
    "watch:css": "sass --quiet-deps --load-path=. --load-path=node_modules --watch src/assets/scss:dist/assets/css",
    "dev": "npm-run-all -p watch:css serve"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@ministryofjustice/frontend": "^9.0.0",
    "csv-parse": "^5.6.0",
    "govuk-frontend": "^6.0.0",
    "luxon": "^3.6.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "sass": "^1.86.0"
  }
}

