{# GOV.UK Tabs styling used for navigation between browse modes #}
{% set p = pagePath or "" %}
{% set isMethod = p.indexOf("/browse/by-ai-method") == 0 %}
{% set isOrg = p.indexOf("/browse/by-organisation") == 0 %}
{% set isOrigin = p.indexOf("/browse/by-origin") == 0 %}
{% set isStatus = p.indexOf("/browse/by-status") == 0 %}
{% set isUsecase = p.indexOf("/browse/by-usecase") == 0 %}

<div class="govuk-tabs" data-module="govuk-tabs">
  <h2 class="govuk-tabs__title">Browse tools</h2>
  <ul class="govuk-tabs__list">
    <li class="govuk-tabs__list-item">
      <a class="govuk-tabs__tab" href="/">All tools</a>
    </li>
    <li class="govuk-tabs__list-item{% if isMethod %} govuk-tabs__list-item--selected{% endif %}">
      <a class="govuk-tabs__tab" href="/browse/by-ai-method/">By AI method</a>
    </li>
    <li class="govuk-tabs__list-item{% if isOrg %} govuk-tabs__list-item--selected{% endif %}">
      <a class="govuk-tabs__tab" href="/browse/by-organisation/">By organisation</a>
    </li>
    <li class="govuk-tabs__list-item{% if isOrigin %} govuk-tabs__list-item--selected{% endif %}">
      <a class="govuk-tabs__tab" href="/browse/by-origin/">By origin</a>
    </li>
    <li class="govuk-tabs__list-item{% if isStatus %} govuk-tabs__list-item--selected{% endif %}">
      <a class="govuk-tabs__tab" href="/browse/by-status/">By status</a>
    </li>
    <li class="govuk-tabs__list-item{% if isUsecase %} govuk-tabs__list-item--selected{% endif %}">
      <a class="govuk-tabs__tab" href="/browse/by-usecase/">By usecase</a>
    </li>
  </ul>
</div>

