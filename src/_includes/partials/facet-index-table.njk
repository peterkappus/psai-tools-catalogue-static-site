{% from "govuk/components/table/macro.njk" import govukTable %}

{% set rows = [] %}
{% for entry in facetEntries %}
  {% set rows = (rows.push([
    { html: '<a class="govuk-link" href="' ~ facetBasePath ~ entry.slug ~ '/">' ~ (entry.name | escape) ~ '</a>' },
    { text: entry.tools | length, format: "numeric" }
  ]), rows) %}
{% endfor %}

{{ govukTable({
  head: [
    { text: facetLabelColumn },
    { text: "Number of tools", format: "numeric" }
  ],
  rows: rows
}) }}
