<h1 class="govuk-heading-xl">Browse by AI method</h1>
<p class="govuk-body app-muted">Methods are split on commas and synonyms are normalised where possible.</p>

{% include "partials/browse-tabs.njk" %}

<ul class="govuk-list">
  {% for m in listing.entries %}
    <li>
      <a class="govuk-link" href="/browse/by-ai-method/{{ m.slug }}/">{{ m.name }}</a>
      <span class="app-list-count">({{ m.tools | length }})</span>
    </li>
  {% endfor %}
</ul>

{% set pager = { pageNumber: listing.pageNumber, totalPages: listing.totalPages, basePermalink: "/browse/by-ai-method/" } %}
{% include "partials/pager.njk" %}

